{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/square-install-post-seed",
      "schedule": "* 14-23,0 * * *"
    },
    {
      "path": "/api/cron/square-refresh",
      "schedule": "0 15,17,19,21,23,1 * * *"
    },
    {
      "path": "/api/cron/jobs-snapshot",
      "schedule": "0 8 * * 0"
    }
  ]
}
